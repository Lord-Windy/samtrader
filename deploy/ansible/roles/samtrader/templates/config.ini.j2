[database]
backend = {{ samtrader_db_backend | default('sqlite') }}

{% if samtrader_db_backend | default('sqlite') == 'postgres' %}
[postgres]
connection_string = postgresql://{{ samtrader_pg_user }}:{{ samtrader_pg_password }}@127.0.0.1:5432/{{ samtrader_pg_database }}
pool_size = {{ samtrader_pg_pool_size | default(10) }}
{% else %}
[sqlite]
path = {{ samtrader_db_path }}
{% endif %}

[server]
host = 127.0.0.1
port = {{ samtrader_web_port }}

[auth]
username = {{ samtrader_auth_username }}
# password: set via ansible-vault variable samtrader_auth_password
{% if samtrader_auth_password is defined %}
password = {{ samtrader_auth_password }}
{% endif %}
session_secret = {{ samtrader_session_secret }}

[backup]
destination = {{ samtrader_backup_dir }}
retention_daily = 7
retention_weekly = 4
retention_monthly = 3
